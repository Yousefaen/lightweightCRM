# Supabase (client-side — safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (used by Vercel serverless functions)
ANTHROPIC_API_KEY=sk-ant-your-key-here
HUNTER_API_KEY=your-hunter-key-here

# Vercel Cron (used by /api/cron/daily-outbound)
# - SUPABASE_SERVICE_ROLE_KEY: from Supabase dashboard → Settings → API → service_role
#   Bypasses RLS so the cron can write contacts and drafts on behalf of the system.
#   NEVER expose this to the client bundle. Only set it in Vercel dashboard.
# - CRON_SECRET: any random 32+ character string. Vercel automatically sends this
#   as `Authorization: Bearer <CRON_SECRET>` on cron invocations. Set in Vercel dashboard.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
CRON_SECRET=generate-a-random-32-character-string
